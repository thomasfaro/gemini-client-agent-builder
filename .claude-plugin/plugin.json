{
  "name": "airship",
  "version": "1.2.0",
  "description": "Airship SDK tools — push notifications, channels, migrations, RTDS, and wallet.",
  "author": { "name": "Airship", "url": "https://airship.com" },
  "repository": "https://github.com/urbanairship/agent-tools",
  "license": "Apache-2.0",
  "skills": [
    "./skills/api/channel-listing",
    "./skills/api/create-pipeline",
    "./skills/api/custom-events",
    "./skills/api/email-lookup",
    "./skills/api/email-registration",
    "./skills/api/email-replace",
    "./skills/api/list-pipelines",
    "./skills/api/named-users",
    "./skills/api/open-channel-registration",
    "./skills/api/push-notification",
    "./skills/api/reports",
    "./skills/api/sms-lookup",
    "./skills/api/sms-registration",
    "./skills/api/tags",
    "./skills/mobile/custom-views",
    "./skills/mobile/message-center",
    "./skills/mobile/migration",
    "./skills/mobile/push",
    "./skills/mobile/sdk-reference",
    "./skills/rtds/rtds-connection",
    "./skills/wallet/update-wallet-pass",
    "./skills/workflows/app-activity-summary",
    "./skills/workflows/complete-user-onboarding",
    "./skills/workflows/create-custom-event-automation",
    "./skills/workflows/custom-event-automation-discovery",
    "./skills/workflows/download-entire-audience",
    "./skills/workflows/extract-unique-tags-and-attributes",
    "./skills/workflows/open-channel-middleware",
    "./skills/workflows/purchase-to-pass-update",
    "./skills/workflows/push-performance-analysis",
    "./skills/workflows/register-associate-email",
    "./skills/workflows/register-associate-sms",
    "./skills/workflows/replace-email-address",
    "./skills/workflows/rtds-monitoring"
  ],
  "mcpServers": {
    "airship-mcp": {
      "command": "uv",
      "args": ["run", "--directory", "${CLAUDE_PLUGIN_ROOT}", "airship-mcp"],
      "env": {
        "AIRSHIP_APP_KEY": "${AIRSHIP_APP_KEY}",
        "AIRSHIP_CLIENT_ID": "${AIRSHIP_CLIENT_ID}",
        "AIRSHIP_CLIENT_SECRET": "${AIRSHIP_CLIENT_SECRET}",
        "AIRSHIP_REGION": "${AIRSHIP_REGION}"
      }
    }
  }
}
